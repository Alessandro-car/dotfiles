# font_family Iosevka Regular
font_size 12

cursor_shap block

enable_audio_bell no

draw_minimal_borders yes


# BEGIN_KITTY_THEME
# Atelier Dune Dark
include current-theme.conf
# END_KITTY_THEME

# BEGIN_KITTY_FONTS
font_family      family="Iosevka Fixed"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS